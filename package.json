<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>ProCool HVAC – Owner App</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', sans-serif; background: #0d1b2a; color: #e0e0e0; min-height: 100vh; }

    header {
      background: #0d47a1; padding: 16px 24px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .header-left { display: flex; align-items: center; gap: 12px; }
    .icon { font-size: 1.6rem; }
    header h1 { font-size: 1.2rem; font-weight: 700; color: white; }
    header p { font-size: 0.78rem; color: rgba(255,255,255,0.7); margin-top: 2px; }
    .refresh-btn {
      background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.3);
      color: white; padding: 8px 16px; border-radius: 8px; cursor: pointer; font-size: 0.85rem;
    }
    .refresh-btn:hover { background: rgba(255,255,255,0.25); }

    .stats { display: flex; gap: 12px; padding: 20px 24px; overflow-x: auto; }
    .stat-card { background: #1a2a3a; border-radius: 12px; padding: 14px 18px; min-width: 110px; flex: 1; border-left: 4px solid; }
    .stat-card.total { border-color: #1a73e8; }
    .stat-card.pending { border-color: #f59e0b; }
    .stat-card.confirmed { border-color: #10b981; }
    .stat-card.done { border-color: #6366f1; }
    .stat-card .num { font-size: 1.8rem; font-weight: 700; color: white; }
    .stat-card .label { font-size: 0.75rem; color: #aaa; margin-top: 2px; text-transform: uppercase; }

    .filter-bar { display: flex; gap: 8px; padding: 8px 24px 16px; overflow-x: auto; }
    .filter-btn {
      padding: 6px 14px; border-radius: 20px; border: 1.5px solid #333;
      background: transparent; color: #aaa; font-size: 0.8rem; cursor: pointer; white-space: nowrap;
    }
    .filter-btn.active, .filter-btn:hover { background: #1a73e8; border-color: #1a73e8; color: white; }

    .bookings-list { padding: 0 24px 32px; display: flex; flex-direction: column; gap: 12px; }

    .booking-card {
      background: #1a2a3a; border-radius: 12px; padding: 18px 20px; border: 1px solid #2a3a4a;
    }
    .booking-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10px; }
    .customer-name { font-size: 1.05rem; font-weight: 700; color: white; margin-bottom: 4px; }
    .service-tag { background: #1a73e8; color: white; font-size: 0.72rem; padding: 3px 10px; border-radius: 20px; font-weight: 600; white-space: nowrap; }
    .booking-details { display: grid; grid-template-columns: 1fr 1fr; gap: 5px 16px; margin-bottom: 12px; }
    .detail { font-size: 0.82rem; color: #aaa; display: flex; align-items: center; gap: 5px; }
    .detail span { color: #ddd; }
    .notes-text { font-size: 0.8rem; color: #888; font-style: italic; margin-bottom: 12px; padding: 8px 12px; background: rgba(255,255,255,0.04); border-radius: 8px; }
    .booking-actions { display: flex; gap: 8px; flex-wrap: wrap; }
    .action-btn { padding: 6px 14px; border-radius: 8px; border: none; font-size: 0.8rem; font-weight: 600; cursor: pointer; }
    .btn-confirm { background: #10b981; color: white; }
    .btn-done { background: #6366f1; color: white; }
    .btn-cancel { background: #ef4444; color: white; }
    .btn-delete { background: #374151; color: white; }

    .status-badge { display: inline-block; padding: 3px 10px; border-radius: 20px; font-size: 0.75rem; font-weight: 600; }
    .status-Pending { background: #7c4f00; color: #fbbf24; }
    .status-Confirmed { background: #064e3b; color: #34d399; }
    .status-Completed { background: #312e81; color: #a5b4fc; }
    .status-Cancelled { background: #450a0a; color: #fca5a5; }

    .empty-state { text-align: center; padding: 60px 20px; color: #555; }
    .empty-state .icon { font-size: 3rem; margin-bottom: 12px; }

    @media (max-width: 480px) {
      .booking-details { grid-template-columns: 1fr; }
      header h1 { font-size: 1rem; }
    }
  </style>
</head>
<body>

<header>
  <div class="header-left">
    <div class="icon">❄️</div>
    <div>
      <h1>Owner Dashboard</h1>
      <p>ProCool HVAC · Prosper, TX</p>
    </div>
  </div>
  <button class="refresh-btn" onclick="loadBookings()">🔄 Refresh</button>
</header>

<div class="stats">
  <div class="stat-card total"><div class="num" id="statTotal">–</div><div class="label">Total</div></div>
  <div class="stat-card pending"><div class="num" id="statPending">–</div><div class="label">Pending</div></div>
  <div class="stat-card confirmed"><div class="num" id="statConfirmed">–</div><div class="label">Confirmed</div></div>
  <div class="stat-card done"><div class="num" id="statDone">–</div><div class="label">Done</div></div>
</div>

<div class="filter-bar">
  <button class="filter-btn active" onclick="setFilter('All',this)">All</button>
  <button class="filter-btn" onclick="setFilter('Pending',this)">Pending</button>
  <button class="filter-btn" onclick="setFilter('Confirmed',this)">Confirmed</button>
  <button class="filter-btn" onclick="setFilter('Completed',this)">Completed</button>
  <button class="filter-btn" onclick="setFilter('Cancelled',this)">Cancelled</button>
</div>

<div class="bookings-list" id="bookingsList">
  <div class="empty-state"><div class="icon">⏳</div><p>Loading bookings...</p></div>
</div>

<script>
  let allBookings = [];
  let currentFilter = 'All';

  async function loadBookings() {
    try {
      const res = await fetch('/api/bookings');
      allBookings = await res.json();
      updateStats();
      renderBookings();
    } catch {
      document.getElementById('bookingsList').innerHTML =
        '<div class="empty-state"><div class="icon">⚠️</div><p>Could not load bookings.</p></div>';
    }
  }

  function updateStats() {
    document.getElementById('statTotal').textContent = allBookings.length;
    document.getElementById('statPending').textContent = allBookings.filter(b => b.status === 'Pending').length;
    document.getElementById('statConfirmed').textContent = allBookings.filter(b => b.status === 'Confirmed').length;
    document.getElementById('statDone').textContent = allBookings.filter(b => b.status === 'Completed').length;
  }

  function setFilter(filter, btn) {
    currentFilter = filter;
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    renderBookings();
  }

  function renderBookings() {
    const list = document.getElementById('bookingsList');
    const filtered = currentFilter === 'All' ? allBookings : allBookings.filter(b => b.status === currentFilter);
    if (!filtered.length) {
      list.innerHTML = '<div class="empty-state"><div class="icon">📭</div><p>No bookings found.</p></div>';
      return;
    }
    list.innerHTML = filtered.map(b => `
      <div class="booking-card">
        <div class="booking-top">
          <div>
            <div class="customer-name">${b.first_name} ${b.last_name}</div>
            <span class="status-badge status-${b.status}">${b.status}</span>
          </div>
          <span class="service-tag">${b.service || 'General'}</span>
        </div>
        <div class="booking-details">
          <div class="detail">📅 <span>${b.date}</span></div>
          <div class="detail">🕐 <span>${b.time}</span></div>
          <div class="detail">✉️ <span>${b.email}</span></div>
          <div class="detail">📞 <span>${b.phone || 'Not provided'}</span></div>
        </div>
        ${b.notes ? `<div class="notes-text">💬 ${b.notes}</div>` : ''}
        <div class="booking-actions">
          ${b.status === 'Pending' ? `<button class="action-btn btn-confirm" onclick="updateStatus(${b.id},'Confirmed')">✅ Confirm</button>` : ''}
          ${b.status === 'Confirmed' ? `<button class="action-btn btn-done" onclick="updateStatus(${b.id},'Completed')">🏁 Mark Done</button>` : ''}
          ${b.status !== 'Cancelled' && b.status !== 'Completed' ? `<button class="action-btn btn-cancel" onclick="updateStatus(${b.id},'Cancelled')">✖ Cancel</button>` : ''}
          <button class="action-btn btn-delete" onclick="deleteBooking(${b.id})">🗑 Delete</button>
        </div>
      </div>
    `).join('');
  }

  async function updateStatus(id, status) {
    await fetch(`/api/bookings?id=${id}`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ status })
    });
    loadBookings();
  }

  async function deleteBooking(id) {
    if (!confirm('Delete this booking?')) return;
    await fetch(`/api/bookings?id=${id}`, { method: 'DELETE' });
    loadBookings();
  }

  loadBookings();
  setInterval(loadBookings, 30000);
</script>
</body>
</html>
